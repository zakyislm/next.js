{
  "name": "@next/font",
  "private": true,
  "version": "16.3.0-canary.59",
  "repository": {
    "url": "vercel/next.js",
    "directory": "packages/font"
  },
  "types": "dist/types.d.ts",
  "files": [
    "dist",
    "google",
    "local"
  ],
  "license": "MIT",
  "scripts": {
    "build": "node ../../scripts/rm.mjs dist && pnpm ncc-fontkit && tsc -d -p tsconfig.build.json",
    "dev": "pnpm ncc-fontkit && tsc -d -w -p tsconfig.json",
    "typescript": "tsec --noEmit -p tsconfig.json",
    "ncc-fontkit": "ncc build ./fontkit.js --minify -o dist/fontkit",
    "pack-for-isolated-tests": "pnpm pack --out ./packed.tgz"
  },
  "devDependencies": {
    "@types/fontkit": "2.0.0",
    "@vercel/ncc": "0.38.4",
    "fontkit": "2.0.2",
    "typescript": "6.0.2"
  }
}
